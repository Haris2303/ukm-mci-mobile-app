    "@tanstack/react-query": "^5.100.14",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.34",
    "expo-barcode-scanner": "^13.0.1",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
